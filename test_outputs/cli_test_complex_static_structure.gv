strict digraph StructureGraph {
    graph [ordering=in rankdir=LR]
    node [style=filled shape=plaintext fontsize=10]
    edge [fontsize=10]

    root [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
        <TR>
            <TD BGCOLOR="#F0F0F0">input<BR/></TD>
            <TD>ComplexNet<BR/>depth: 0</TD>
            <TD BGCOLOR="#F0F0F0">output<BR/></TD>
        </TR>
        </TABLE>
    > fillcolor=darkseagreen1 vode_type="module" vode_depth="0" vode_module_type="ComplexNet" vode_params="{\"total_params\": 1270, \"trainable_params\": 1270}"]
    layers [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
