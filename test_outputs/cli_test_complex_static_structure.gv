    > fillcolor=darkseagreen1 vode_type="module" vode_depth="2" vode_module_type="Linear" vode_params="{\"total_params\": 420, \"trainable_params\": 420, \"in_features\": 20, \"out_features\": 20}"]
    layers_3 [label=<
