        </TR>
        </TABLE>
    > fillcolor=darkseagreen1 vode_type="module" vode_depth="1" vode_module_type="ModuleList" vode_params="{\"total_params\": 1270, \"trainable_params\": 1270}"]
    layers_0 [label=<
