digraph ComputationGraph {
    graph [ordering=in rankdir=LR size="12.0,12.0"]
    node [align=left fontname="Linux libertine" fontsize=10 height=0.2 margin=0 ranksep=0.1 shape=plaintext style=filled]
    edge [fontsize=10]

    nmodule_0 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
                    <TR>
                        <TD ROWSPAN="2">SimpleModel<BR/>depth:0</TD>
                        <TD COLSPAN="2">input:</TD>
                        <TD COLSPAN="2">(2, 10)</TD>
                    </TR>
                    <TR>
                        <TD COLSPAN="2">output:</TD>
                        <TD COLSPAN="2">(2, 5)</TD>
                    </TR>
                    </TABLE>> fillcolor=darkseagreen1]

    ninput_tensor_1 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
                        <TR><TD>input_0<BR/>depth:0</TD><TD>(2, 10), float32</TD></TR>
                    </TABLE>> fillcolor=lightyellow]

    nmodule_2 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
                    <TR>
                        <TD ROWSPAN="2">Linear<BR/>depth:0</TD>
                        <TD COLSPAN="2">input:</TD>
                        <TD COLSPAN="2">(2, 10)</TD>
                    </TR>
                    <TR>
                        <TD COLSPAN="2">output:</TD>
                        <TD COLSPAN="2">(2, 20)</TD>
                    </TR>
                    </TABLE>> fillcolor=darkseagreen1]

    noutput_tensor_3 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
                        <TR><TD>output_0<BR/>depth:0</TD><TD>(2, 20), float32</TD></TR>
                    </TABLE>> fillcolor=lightyellow]

    nmodule_4 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
                    <TR>
                        <TD ROWSPAN="2">ReLU<BR/>depth:0</TD>
                        <TD COLSPAN="2">input:</TD>
                        <TD COLSPAN="2">(2, 20)</TD>
                    </TR>
                    <TR>
                        <TD COLSPAN="2">output:</TD>
                        <TD COLSPAN="2">(2, 20)</TD>
                    </TR>
                    </TABLE>> fillcolor=darkseagreen1]

    noutput_tensor_5 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
                        <TR><TD>output_0<BR/>depth:0</TD><TD>(2, 20), float32</TD></TR>
                    </TABLE>> fillcolor=lightyellow]

    nmodule_6 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
                    <TR>
                        <TD ROWSPAN="2">Linear<BR/>depth:0</TD>
                        <TD COLSPAN="2">input:</TD>
                        <TD COLSPAN="2">(2, 20)</TD>
                    </TR>
                    <TR>
                        <TD COLSPAN="2">output:</TD>
                        <TD COLSPAN="2">(2, 5)</TD>
                    </TR>
                    </TABLE>> fillcolor=darkseagreen1]

    noutput_tensor_7 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
                        <TR><TD>output_0<BR/>depth:0</TD><TD>(2, 5), float32</TD></TR>
                    </TABLE>> fillcolor=lightyellow]

    ninput_tensor_1 -> nmodule_0 [label="(2, 10)"]
    ninput_tensor_1 -> nmodule_2 [label="(2, 10)"]
    nmodule_2 -> noutput_tensor_3
    noutput_tensor_3 -> nmodule_4 [label="(2, 20)"]
    nmodule_4 -> noutput_tensor_5
    noutput_tensor_5 -> nmodule_6 [label="(2, 20)"]
    nmodule_6 -> noutput_tensor_7
    nmodule_0 -> noutput_tensor_7
}